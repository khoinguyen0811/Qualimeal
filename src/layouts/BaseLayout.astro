---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  keywords?: string;
  page: string;
}

const { title, description, keywords, page } = Astro.props;
---

<!DOCTYPE html>
<html lang="vi" class="scroll-smooth">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    
    {description && <meta name="description" content={description} />}
    {keywords && <meta name="keywords" content={keywords} />}
    
    <!-- FontAwesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <!-- Preconnect and Google Fonts link -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Montserrat:ital,wght@0,100..900;1,100..900&family=Open+Sans:ital,wght@0,300..800;1,300..800&display=swap" rel="stylesheet" />

    <!-- Slot for page-specific head injections if any -->
    <slot name="head" />
</head>
<body class="bg-brand-beige text-[#2d3527] font-sans antialiased overflow-x-hidden" data-page={page}>
    <slot />
    
    <!-- Client side script -->
    <script src="../scripts/app.js"></script>
</body>
</html>
