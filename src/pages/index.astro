---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import InteractiveAccordion from '../components/InteractiveAccordion.astro';
import Services from '../components/Services.astro';
import Rd from '../components/Rd.astro';
import Applications from '../components/Applications.astro';
import Blog from '../components/Blog.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import Modals from '../components/Modals.astro';
---

<BaseLayout
  title="QualiMeal - Khoa Học Công Nghệ, R&D & Chứng Nhận ISO Thực Phẩm"
  description="QualiMeal - Đơn vị hàng đầu cung cấp dịch vụ khoa học công nghệ, nghiên cứu phát triển sản phẩm (R&D) thực phẩm, tư vấn chứng nhận hệ thống quản lý ISO 9001, ISO 22000, HACCP và vệ sinh an toàn thực phẩm."
  keywords="QualiMeal, chứng nhận ISO, R&D thực phẩm, an toàn thực phẩm, kiểm nghiệm thực phẩm, khoa học công nghệ thực phẩm"
  page="index"
>
  <Header />

  <Hero />

  <About />

  <InteractiveAccordion />

  <Services />

  <Rd />

  <Applications />

  <Blog />

  <Contact />

  <Footer />

  <Modals />
</BaseLayout>
