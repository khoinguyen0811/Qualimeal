---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Rd from '../components/Rd.astro';
import Footer from '../components/Footer.astro';
import Modals from '../components/Modals.astro';
---

<BaseLayout
  title="Nghiên Cứu & Phát Triển Sản Phẩm (R&D) - QualiMeal"
  description="Trung tâm nghiên cứu phát triển R&D QualiMeal giúp tối ưu hóa công thức thực phẩm, gia tốc hạn sử dụng sản phẩm và chuyển giao công nghệ quy mô công nghiệp."
  keywords="R&D thực phẩm, phát triển sản phẩm mới, chuyển giao công nghệ thực phẩm"
  page="rd"
>
  <Header />

  <!-- Page Title Banner -->
  <div class="bg-slate-900 text-white py-12 px-6 relative overflow-hidden">
      <div class="absolute inset-0 bg-cover bg-center opacity-25" style="background-image: url('/assets/banners/banner2.jpg');"></div>
      <div class="max-w-7xl mx-auto relative z-10 text-center space-y-3">
          <h1 class="font-display font-extrabold text-3xl md:text-4xl text-white">Nghiên Cứu & Phát Triển (R&D)</h1>
          <p class="text-sm text-slate-300 max-w-lg mx-auto">Chuyển giao giải pháp kỹ thuật, tối ưu hóa công thức sản xuất thực phẩm quy mô lớn.</p>
      </div>
  </div>

  <Rd />

  <!-- Extra Lab Capacity Section -->
  <section class="py-12 bg-white border-t border-slate-100">
      <div class="max-w-7xl mx-auto px-6 md:px-8">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
              <div>
                  <h3 class="font-display font-extrabold text-2xl text-brand-deep mb-4">Năng lực Phòng R&D Thí Nghiệm</h3>
                  <p class="text-slate-600 text-sm leading-relaxed mb-4">
                      Chúng tôi trang bị các hệ thống thiết bị pilot hiện đại giả lập hoàn hảo dây chuyền nhà máy thực tế. Giúp tối thiểu hóa rủi ro và chi phí khi chuyển giao công thức từ phòng thí nghiệm ra sản xuất quy mô công nghiệp.
                  </p>
                  <ul class="space-y-2 text-xs font-bold text-slate-700">
                      <li><i class="fa-solid fa-circle-check text-brand-gold mr-2"></i> Hệ thống thanh trùng UHT thu nhỏ</li>
                      <li><i class="fa-solid fa-circle-check text-brand-gold mr-2"></i> Máy đồng hóa áp suất cao</li>
                      <li><i class="fa-solid fa-circle-check text-brand-gold mr-2"></i> Tủ vi khí hậu gia tốc lão hóa mẫu</li>
                  </ul>
              </div>
              <div>
                  <img src="/assets/banners/banner8.jpg" alt="Phòng Thí Nghiệm R&D" class="rounded-3xl shadow-xl w-full h-[280px] object-cover border border-slate-200" />
              </div>
          </div>
      </div>
  </section>

  <Footer />
  <Modals />
</BaseLayout>
