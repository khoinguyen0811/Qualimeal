---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import Modals from '../components/Modals.astro';
---

<BaseLayout
  title="Liên Hệ Với Chúng Tôi - QualiMeal"
  description="Liên hệ với QualiMeal để được tư vấn chứng nhận ISO 22000, HACCP, GMP, R&D thực phẩm nhanh chóng, chuyên nghiệp và uy tín hàng đầu."
  keywords="liên hệ QualiMeal, địa chỉ phòng lab, hotline an toàn thực phẩm"
  page="contact"
>
  <Header />

  <!-- Page Title Banner -->
  <div class="bg-slate-900 text-white py-12 px-6 relative overflow-hidden">
      <div class="absolute inset-0 bg-cover bg-center opacity-25" style="background-image: url('/assets/banners/banner1.jpg');"></div>
      <div class="max-w-7xl mx-auto relative z-10 text-center space-y-3">
          <h1 class="font-display font-extrabold text-3xl md:text-4xl text-white">Liên Hệ Tư Vấn</h1>
          <p class="text-sm text-slate-300 max-w-lg mx-auto">Đội ngũ chuyên gia của chúng tôi luôn sẵn sàng hỗ trợ doanh nghiệp của bạn 24/7.</p>
      </div>
  </div>

  <Contact />

  <!-- Location Map Emulation (Google Map Placeholder for visual premium feeling) -->
  <section class="py-12 bg-white border-t border-slate-100">
      <div class="max-w-7xl mx-auto px-6 md:px-8 space-y-6">
          <h3 class="font-display font-extrabold text-xl text-brand-deep text-center">Bản Đồ Chỉ Đường</h3>
          <div class="w-full h-[350px] bg-slate-100 rounded-3xl border border-slate-200 shadow-md relative overflow-hidden flex items-center justify-center">
              <!-- Decorative map placeholder image -->
              <div class="absolute inset-0 bg-cover bg-center opacity-75" style="background-image: url('https://images.unsplash.com/photo-1524661135-423995f22d0b?q=80&w=1200&auto=format&fit=crop');"></div>
              <div class="absolute inset-0 bg-brand-deep/30"></div>
              <div class="relative z-10 text-center text-white bg-brand-deep/90 p-6 rounded-2xl border border-white/10 max-w-md">
                  <i class="fa-solid fa-map-location-dot text-brand-gold text-3xl mb-3"></i>
                  <h4 class="font-bold text-sm">Văn Phòng Qualimeals</h4>
                  <p class="text-[11px] text-slate-300 mt-1">66 Đường 270 Cao Lỗ, Phường Chánh Hưng, Thành phố Hồ Chí Minh</p>
                  <a href="https://maps.google.com" target="_blank" class="mt-4 inline-flex items-center text-xs text-brand-gold font-bold hover:underline">
                      <span>Mở trong Google Maps</span>
                      <i class="fa-solid fa-arrow-up-right-from-square ml-1.5"></i>
                  </a>
              </div>
          </div>
      </div>
  </section>

  <Footer />
  <Modals />
</BaseLayout>
