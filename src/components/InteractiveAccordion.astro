<!-- ==========================================
     3. DỊCH VỤ ĐẶC TRƯNG (FULL-HEIGHT & FULL-WIDTH STATEFUL INTERACTIVE ACCORDION)
     ========================================== -->
<section id="interactive-accordion-section" class="relative overflow-hidden bg-cover bg-center bg-no-repeat bg-slate-900 z-10 w-full h-[600px] lg:h-[700px]" style="background-image: url('assets/banners/banner2.jpg');">
    <!-- Dark mask overlay for section readability -->
    <div class="absolute inset-0 bg-black/15 z-0"></div>

    <!-- Giant outline decoration text in background (floating on top of panels but behind text) -->
    <div class="absolute top-12 left-0 right-0 w-full overflow-hidden pointer-events-none select-none z-20">
        <h2 class="text-6xl md:text-8xl font-black uppercase text-outline-white tracking-wider opacity-20 whitespace-nowrap animate-pulse">
            YOUR TRUE PARTNER YOUR TRUE PARTNER YOUR TRUE PARTNER
        </h2>
    </div>

    <!-- Full-Width & Full-Height Accordion Box (stretched edge-to-edge, filling 100% of parent section height) -->
    <div class="accordion-container flex flex-col lg:flex-row w-full h-full overflow-hidden relative z-10 bg-black/5">
        
        <!-- Panel 1: NGUYÊN LIỆU KHOA HỌC ĐỜI SỐNG -->
        <div class="accordion-panel active relative transition-all duration-700 ease-in-out cursor-pointer overflow-hidden h-full border-b lg:border-b-0 lg:border-r border-white/10 group" data-bg="assets/banners/banner2.jpg">
            <!-- Backdrop Blur Overlay for inactive state (using white frosted glass theme, custom light blur and opacity) -->
            <div class="accordion-blur-overlay absolute inset-0 backdrop-blur-[5px] bg-white/15 z-10"></div>
            
            <!-- Content -->
            <div class="absolute inset-0 flex flex-col justify-end p-8 md:p-12 text-white z-30">
                <div class="max-w-xl transition-all duration-500 ease-in-out lg:pl-16 xl:pl-32">
                    <div class="flex items-center space-x-3 mb-3">
                        <span class="h-5 w-[3px] bg-brand-gold rounded-full"></span>
                        <h4 class="accordion-title font-display font-extrabold text-lg md:text-xl uppercase tracking-wider">
                            Khoa Học
                        </h4>
                    </div>
                    <p class="desc text-xs md:text-sm text-slate-200 leading-relaxed">
                        Sản phẩm, dịch vụ được xây dựng dựa trên cơ sở nghiên cứu R&D, xây dựng qui trình công nghệ…, các giải pháp cải tiến qui trình ở các công đoạn luôn được vận hành một cách khoa học và phù hợp.
                    </p>
                </div>
                
                <!-- Circle arrow button -->
                <div class="arrow-btn absolute bottom-8 right-8 w-12 h-12 rounded-full bg-brand-gold text-white flex items-center justify-center shadow-lg">
                    <i class="fa-solid fa-arrow-right text-lg transform -rotate-45"></i>
                </div>
            </div>
        </div>

        <!-- Panel 2: NGUYÊN LIỆU VÀ SẢN PHẨM THÀNH PHẨM -->
        <div class="accordion-panel relative transition-all duration-700 ease-in-out cursor-pointer overflow-hidden h-full border-b lg:border-b-0 lg:border-r border-white/10 group" data-bg="assets/banners/banner5.jpg">
            <!-- Backdrop Blur Overlay for inactive state (using white frosted glass theme, custom light blur and opacity) -->
            <div class="accordion-blur-overlay absolute inset-0 backdrop-blur-[5px] bg-white/15 z-10"></div>
            
            <!-- Content -->
            <div class="absolute inset-0 flex flex-col justify-end p-8 md:p-12 text-white z-30">
                <div class="max-w-xl transition-all duration-500 ease-in-out">
                    <div class="flex items-center space-x-3 mb-3">
                        <span class="h-5 w-[3px] bg-brand-gold rounded-full"></span>
                        <h4 class="accordion-title font-display font-extrabold text-lg md:text-xl uppercase tracking-wider">
                            Giải Pháp Thực Phẩm
                        </h4>
                    </div>
                    <p class="desc text-xs md:text-sm text-slate-200 leading-relaxed">
                        Các qui trình công nghệ, chính sách được hành động đồng bộ và phù hợp để đảm bảo sự an toàn, chất lượng và tối ưu hóa chuỗi cung ứng từ khâu nuôi trồng, nghiên cứu R&D, chế biến đến khi đến tay người tiêu dùng.
                    </p>
                </div>
                
                <!-- Circle arrow button -->
                <div class="arrow-btn absolute bottom-8 right-8 w-12 h-12 rounded-full bg-brand-gold text-white flex items-center justify-center shadow-lg">
                    <i class="fa-solid fa-arrow-right text-lg transform -rotate-45"></i>
                </div>
            </div>
        </div>

        <!-- Panel 3: DỊCH VỤ HẬU CẦN CHUYÊN NGHIỆP -->
        <div class="accordion-panel relative transition-all duration-700 ease-in-out cursor-pointer overflow-hidden h-full group" data-bg="assets/banners/banner6.jpg">
            <!-- Backdrop Blur Overlay for inactive state (using white frosted glass theme, custom light blur and opacity) -->
            <div class="accordion-blur-overlay absolute inset-0 backdrop-blur-[5px] bg-white/15 z-10"></div>
            
            <!-- Content -->
            <div class="absolute inset-0 flex flex-col justify-end p-8 md:p-12 text-white z-30">
                <div class="max-w-xl transition-all duration-500 ease-in-out lg:pr-16 xl:pr-32">
                    <div class="flex items-center space-x-3 mb-3">
                        <span class="h-5 w-[3px] bg-brand-gold rounded-full"></span>
                        <h4 class="accordion-title font-display font-extrabold text-lg md:text-xl uppercase tracking-wider">
                            Chất Lượng
                        </h4>
                    </div>
                    <p class="desc text-xs md:text-sm text-slate-200 leading-relaxed">
                        Chất lượng không chỉ là thỏa mãn nhu cầu mong đợi hay sự thừa nhận của người sử dụng về sản phẩm, dịch vụ. Chất lượng còn là mức độ phù hợp với các yêu cầu đề ra. Sản phẩm, dịch vụ từ mức độ nghiên cứu khoa học, chuỗi cung ứng, chế biến, đến hoàn hiện, các giải pháp xây dựng hay cải tiến cũng cần đáp ứng được các tiêu chuẩn kỹ thuật, TCVN, QCVN…, đồng thời đáp ứng đúng các qui định về phát luật hiện hành. Từ đó mang lại nhiều giá trị sử dụng tích cực cho người sử dụng.
                    </p>
                </div>
                
                <!-- Circle arrow button -->
                <div class="arrow-btn absolute bottom-8 right-8 w-12 h-12 rounded-full bg-brand-gold text-white flex items-center justify-center shadow-lg">
                    <i class="fa-solid fa-arrow-right text-lg transform -rotate-45"></i>
                </div>
            </div>
        </div>

    </div>
</section>
